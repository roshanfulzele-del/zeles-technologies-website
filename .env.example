# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required for dev server
PORT=5173
BASE_PATH=/

# API server session signing (use a strong random string)
SESSION_SECRET=change-me-to-a-strong-random-secret

# PostgreSQL connection (only needed if using the API server + database)
DATABASE_URL=postgresql://user:password@localhost:5432/zeles_db
